# =============================================================================
# Prophet Hacks 2026 - Trading Track agent runtime config (TEMPLATE)
# Copy this file to `.env` and fill in the values, then `bash scripts/run.sh`.
# =============================================================================

# --- Core API (Prophet Arena) ---------------------------------------------------
# PA_SERVER_API_KEY is required. The default URL is the hosted Core API.
PA_SERVER_URL=https://api.aiprophet.dev
PA_SERVER_API_KEY=prophet_xxx_yyy

# --- LLM providers ---------------------------------------------------------------
# Most models are routed through OpenRouter to keep one bill + one budget.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4
CHEAP_MODEL=google/gemini-2.5-flash
FALLBACK_MODELS=google/gemini-2.5-flash,deepseek/deepseek-v3.2

# Direct provider keys (only needed for the corresponding `-m provider:model` spec
# passed to agent.run; the SDK's create_llm_client picks one of these per call).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Retrieval (Tavily primary, DDG fallback, Exa optional) ---------------------
TAVILY_API_KEY=tvly-...
EXA_API_KEY=
# BRAVE is used only if we ever fall back to the SDK's built-in search adapter.
BRAVE_API_KEY=

# --- Budget kill-switch (Phase 4) -----------------------------------------------
COST_DB_PATH=./costs.sqlite
KILL_SWITCH_USD=180

# --- Calibration knobs -----------------------------------------------------------
# Alpha = weight given to the model vs market consensus (1=pure model, 0=pure market).
# Our neutral LLM prompt means the model does NOT pre-anchor to market, so the
# alpha blend is the ONLY anchor. Higher values are appropriate (vs classic 0.5/0.25).
ALPHA_HIGH=0.85
ALPHA_MEDIUM=0.70
ALPHA_LOW=0.40

# Edge thresholds. Slightly relaxed so small but real deviations generate intents.
MIN_EDGE=0.04
MIN_EDGE_RELAXED=0.02

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=INFO
