# =============================================================================
# Prophet Hacks 2026 - Trading Track agent runtime config (TEMPLATE)
# Copy this file to `.env` and fill in the values, then `bash scripts/run.sh`.
# =============================================================================

# --- Core API (Prophet Arena) ---------------------------------------------------
PA_SERVER_URL=https://api.aiprophet.dev
PA_SERVER_API_KEY=prophet_xxx_yyy

# --- LLM (Gemini via Google AI — billed to your GCP project) -------------------
# Get a key at: console.cloud.google.com → APIs & Services → Credentials
# Enable the "Generative Language API" in your GCP project first.
# This bills usage to your GCP project credits.
GEMINI_API_KEY=AIza...

# Kept as fallback only. Remove OPENROUTER_API_KEY if running Gemini-only.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Retrieval ------------------------------------------------------------------
TAVILY_API_KEY=tvly-...
EXA_API_KEY=
BRAVE_API_KEY=

# --- Budget kill-switch ---------------------------------------------------------
# Gemini 2.5 Flash costs ~$32 for a full 14-day run at N=6 ensemble.
# $100 is a very comfortable ceiling; raise or lower as needed.
COST_DB_PATH=./costs.sqlite
KILL_SWITCH_USD=100

# --- Ensemble & edge knobs ------------------------------------------------------
# Gemini 2.5 Flash is ~20x cheaper than Claude Sonnet, so we can afford N=6.
# Set to 1 to disable ensemble (single call, lowest cost, lowest quality).
LLM_ENSEMBLE_N=6

# Raw gap gate: minimum |p_model - p_market| before the blend required to trade.
# Lower than MIN_EDGE because it gates on the pre-blend deviation, not the
# shrunken blended edge. Equivalent to ~0.04 in practice with alpha_medium=0.70.
MIN_RAW_GAP=0.04

# --- Calibration knobs ----------------------------------------------------------
# Alpha = model weight in the p_final blend (1=pure model, 0=pure market).
# Our neutral prompt does NOT pre-anchor to market price, so model weight can
# be higher than the classic 0.5. These apply when conf_model=0 (no ensemble);
# the dynamic_alpha() function overrides these during live ensemble runs.
ALPHA_HIGH=0.85
ALPHA_MEDIUM=0.70
ALPHA_LOW=0.40

# Blended edge thresholds (fallback gate when raw_gap not available).
MIN_EDGE=0.04
MIN_EDGE_RELAXED=0.02

# Max deviation cap: never let p_final deviate more than this from p_market.
MAX_EDGE_DEVIATION=0.30

# --- Logging --------------------------------------------------------------------
LOG_LEVEL=INFO
