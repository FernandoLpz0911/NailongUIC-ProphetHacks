OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4
CHEAP_MODEL=google/gemini-2.5-flash
EXPENSIVE_MODEL=anthropic/claude-opus-4
FALLBACK_MODELS=google/gemini-2.5-flash,deepseek/deepseek-v3.2

# P2 retrieval — set at least one for live news (otherwise DuckDuckGo fallback)
TAVILY_API_KEY=
EXA_API_KEY=

PREDICT_TIMEOUT_SECONDS=180
MODEL_CALL_TIMEOUT_SECONDS=180
CALIBRATION_ALPHA=0.55
MAX_EDGE_DEVIATION=0.30

# Anthropic-style prompt caching via OpenRouter (best-effort; Anthropic models)
USE_PROMPT_CACHE=false

# P3 ensemble — comma-separated OpenRouter model IDs
USE_ENSEMBLE=true
ENSEMBLE_MODELS=anthropic/claude-opus-4,openai/gpt-4o,deepseek/deepseek-r1
COST_DB_PATH=./costs.sqlite
LOG_LEVEL=INFO
